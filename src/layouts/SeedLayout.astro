---
import BaseLayout from './BaseLayout.astro';
import StemDivider from '../components/StemDivider.astro';
import { formatLongDate } from '../utils/formatDate';

interface Props {
  frontmatter: {
    title?: string;
    pubDate: Date;
  };
  slug: string;
}

const { frontmatter, slug } = Astro.props;
const formattedDate = formatLongDate(frontmatter.pubDate);
const pageTitle = frontmatter.title
  ? `${frontmatter.title} - Josiah Nunemaker`
  : `${formattedDate} - Seeds`;
const ogImage = `/og/seeds/${slug}.png`;

const siteUrl = Astro.site!.toString().replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const blogPosting = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: frontmatter.title ?? formattedDate,
  datePublished: frontmatter.pubDate.toISOString(),
  dateModified: frontmatter.pubDate.toISOString(),
  author: {
    '@type': 'Person',
    '@id': `${siteUrl}/#person`,
    name: 'Josiah Nunemaker',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Person',
    '@id': `${siteUrl}/#person`,
    name: 'Josiah Nunemaker',
    url: siteUrl,
  },
  url: canonicalURL,
  mainEntityOfPage: canonicalURL,
  image: `${siteUrl}${ogImage}`,
  isPartOf: { '@id': `${siteUrl}/seeds/#blog` },
};
---

<BaseLayout title={pageTitle} image={ogImage} article publishedTime={frontmatter.pubDate} jsonLd={blogPosting}>
  <main class="max-w-2xl mx-auto px-8 py-20">
    <header class="mb-12 fade-in">
      {frontmatter.title ? (
        <>
          <time class="font-mono text-xs uppercase tracking-wider block mb-4 text-bark">
            {formattedDate}
          </time>
          <h1 class="text-3xl sm:text-4xl font-light tracking-tight mb-6 text-forest">
            {frontmatter.title}
          </h1>
        </>
      ) : (
        <h1 class="font-mono text-xs uppercase tracking-wider mb-6 text-bark">
          <time>{formattedDate}</time>
        </h1>
      )}
      <StemDivider width="short" />
    </header>

    <article class="prose prose-botanical max-w-none fade-in fade-in-delay-1">
      <slot />
    </article>

    <div class="mt-16 pt-8 border-t border-leaf fade-in fade-in-delay-2">
      <a href="/seeds" class="arrow-link font-mono text-sm text-moss">
        ← all seeds
      </a>
    </div>
  </main>
</BaseLayout>
