---
import BaseLayout from './BaseLayout.astro';
import StemDivider from '../components/StemDivider.astro';
import { formatLongDate } from '../utils/formatDate';

interface PostLink {
  slug: string;
  title: string;
}

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    archived?: boolean;
  };
  slug: string;
  readingStats?: { words: number; minutes: number };
  newer?: PostLink | null;
  older?: PostLink | null;
}

const { frontmatter, slug, readingStats, newer, older } = Astro.props;
const formattedDate = formatLongDate(frontmatter.pubDate);

const siteUrl = Astro.site!.toString().replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = `/og/writing/${slug}.png`;
const blogPosting = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: frontmatter.title,
  description: frontmatter.description,
  datePublished: frontmatter.pubDate.toISOString(),
  dateModified: (frontmatter.updatedDate ?? frontmatter.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    '@id': `${siteUrl}/#person`,
    name: 'Josiah Nunemaker',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Person',
    '@id': `${siteUrl}/#person`,
    name: 'Josiah Nunemaker',
    url: siteUrl,
  },
  url: canonicalURL,
  mainEntityOfPage: canonicalURL,
  image: `${siteUrl}${ogImage}`,
};
---

<BaseLayout
  title={`${frontmatter.title} - Josiah Nunemaker`}
  description={frontmatter.description}
  image={ogImage}
  article
  publishedTime={frontmatter.pubDate}
  jsonLd={blogPosting}
>
  <main class="max-w-3xl mx-auto px-8 py-20">
    <header class="mb-16 fade-in">
      <div class="flex items-baseline flex-wrap gap-x-4 gap-y-1 mb-4 font-mono text-xs uppercase tracking-wider text-bark">
        <time>{formattedDate}</time>
        {readingStats && (
          <>
            <span aria-hidden="true" class="opacity-50">·</span>
            <span>{readingStats.minutes} min read</span>
            <span aria-hidden="true" class="opacity-50">·</span>
            <span>{readingStats.words.toLocaleString()} words</span>
          </>
        )}
        {frontmatter.archived && (
          <>
            <span aria-hidden="true" class="opacity-50">·</span>
            <span class="opacity-60">archived</span>
          </>
        )}
      </div>
      <h1 class="text-4xl sm:text-5xl font-light tracking-tight mb-6 text-forest">
        {frontmatter.title}
      </h1>
      <StemDivider width="medium" />
    </header>

    {frontmatter.archived && (
      <aside class="mb-12 border-l-2 border-bark pl-6 py-3 fade-in fade-in-delay-1">
        <p class="text-sage text-sm leading-relaxed">
          This post is kept here for reference. Some information may be out of date.
        </p>
      </aside>
    )}

    <article class="prose prose-botanical prose-lg max-w-none fade-in fade-in-delay-1">
      <slot />
    </article>

    {(newer || older) && (
      <nav
        class="mt-20 pt-8 border-t border-leaf grid sm:grid-cols-2 gap-6 fade-in fade-in-delay-2"
        aria-label="Post navigation"
      >
        <div>
          {older && (
            <a
              href={`/writing/${older.slug}/`}
              class="post-nav-link group block p-6 border-l-2 border-leaf hover:bg-white transition-colors"
            >
              <span class="block font-mono text-xs uppercase tracking-wider text-bark mb-2">
                ← older
              </span>
              <span class="block text-lg font-light leading-snug text-forest">
                {older.title}
              </span>
            </a>
          )}
        </div>
        <div class="sm:text-right">
          {newer && (
            <a
              href={`/writing/${newer.slug}/`}
              class="post-nav-link post-nav-link--right group block p-6 border-r-2 border-leaf hover:bg-white transition-colors"
            >
              <span class="block font-mono text-xs uppercase tracking-wider text-bark mb-2">
                newer →
              </span>
              <span class="block text-lg font-light leading-snug text-forest">
                {newer.title}
              </span>
            </a>
          )}
        </div>
      </nav>
    )}

    <div class="mt-16 pt-8 border-t border-leaf fade-in fade-in-delay-2">
      <a href="/writing" class="arrow-link font-mono text-sm text-moss">
        ← back to writing
      </a>
    </div>
  </main>
</BaseLayout>

<style>
  .post-nav-link {
    border-left-width: 2px;
  }
  .post-nav-link--right {
    border-left-width: 0;
    border-right-width: 2px;
  }
</style>
