---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('writing', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => {
  if (a.data.archived !== b.data.archived) {
    return a.data.archived ? 1 : -1;
  }
  return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});

const description = 'Thoughts on design, development, and the web.';

const siteUrl = Astro.site!.toString().replace(/\/$/, '');
const blog = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${siteUrl}/writing/#blog`,
  url: `${siteUrl}/writing`,
  name: 'Writing',
  description,
  author: { '@id': `${siteUrl}/#person` },
  publisher: { '@id': `${siteUrl}/#person` },
  blogPost: sortedPosts.map((post) => ({
    '@type': 'BlogPosting',
    '@id': `${siteUrl}/writing/${post.slug}`,
    url: `${siteUrl}/writing/${post.slug}`,
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
    author: { '@id': `${siteUrl}/#person` },
    image: `${siteUrl}/og/writing/${post.slug}.png`,
  })),
};
---

<BaseLayout
  title="Writing - Josiah Nunemaker"
  description={description}
  jsonLd={blog}
>
  <main class="max-w-5xl mx-auto px-8 py-20">

    <PageHeader
      title="Writing"
      subtitle="Thoughts taking root on design, development, and the web"
    />

    <div class="space-y-8">
      {sortedPosts.map((post, index) => (
        <div class={`fade-in fade-in-delay-${Math.min(index + 1, 5)}`}>
          <ArticleCard
            title={post.data.title}
            date={post.data.pubDate}
            description={post.data.description}
            slug={post.slug}
            archived={post.data.archived}
          />
        </div>
      ))}
    </div>

    {sortedPosts.length === 0 && (
      <p class="text-lg text-sage fade-in">
        No posts yet. Check back soon.
      </p>
    )}

  </main>
</BaseLayout>
