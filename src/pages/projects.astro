---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";

import prayershareImg from "../assets/projects/prayershare.png";
import sitantImg from "../assets/projects/sitant.png";
import bibleImg from "../assets/projects/bible.png";
import codenamesImg from "../assets/projects/codenames.png";
import ascendImg from "../assets/projects/ascend.png";
import inscribeImg from "../assets/projects/inscribe.png";
import freeRangeIdeasImg from "../assets/projects/free-range-ideas.webp";
import potluckBotImg from "../assets/projects/potluck-bot.webp";
import displayReinitializerImg from "../assets/projects/display-reinitializer.png";
import versetimeImg from "../assets/projects/versetime.png";
import hangtimeImg from "../assets/projects/hangtime.png";
import scribblerigImg from "../assets/projects/scribblerig.png";

const projects = [
    {
        title: "ScribbleRig",
        category: "Web App",
        description:
            "A sharable physics sandbox in your browser. Build simple mechanisms to complex machines, watch them run, and share your creations with your friends.",
        tags: ["TypeScript", "Rapier", "Rough.js", "Cloudflare Workers"],
        image: scribblerigImg,
        imageAlt:
            "Hand-drawn physics sketch with crosshatched beams and wheels, with a sketchy 'ScribbleRig!' title",
        liveUrl: "https://scribblerig.josnun.com",
        repoUrl: "https://github.com/JosNun/scribblerig",
    },
    {
        title: "Inscribe",
        category: "Mobile App",
        description:
            "A scripture memorization app that turns verses into playable, repeatable practice. Spaced repetition keeps them; community keeps you going. Currently in development.",
        tags: ["Flutter", "Bun", "Hono", "PostgreSQL"],
        image: inscribeImg,
        imageAlt:
            "Inscribe app home screen on iPhone showing today's scripture review, verses due now, and saved verse collections",
        liveUrl: "https://inscribe.josnun.com",
    },
    {
        title: "Night Mode Bible",
        category: "Chrome Extension",
        description:
            "A Chrome extension that makes Bible.com easier on your eyes at night with a toggleable dark mode. Featured on the Chrome Web Store at 4.9 stars, and quietly serving 5,000+ weekly active users.",
        tags: ["Chrome Extension", "CSS"],
        image: bibleImg,
        imageAlt:
            "Bible.com displayed in dark mode by the Night Mode Bible Chrome extension, showing the Gospel of John on a dark background",
        liveUrl:
            "https://chromewebstore.google.com/detail/night-mode-bible/ebiieffikaglhelcnogmmijmlejdhngk",
        repoUrl: "https://github.com/JosNun/night-mode-bible",
    },
    {
        title: "Display Reinitializer",
        category: "Raycast Extension",
        description:
            "A Raycast extension to force re-detection and reinitialization of connected displays on macOS. Uses native CoreGraphics APIs and offers multiple reinitialization methods including DDC power-cycle, refresh-rate toggle, and resolution cycle.",
        tags: ["Swift", "Raycast", "macOS"],
        image: displayReinitializerImg,
        imageAlt:
            "Display Reinitializer Raycast command listing connected macOS displays with options for DDC power cycle and refresh-rate toggle",
        liveUrl: "https://www.raycast.com/JosNun/display-reinitializer",
        repoUrl: "https://github.com/JosNun/raycast-reinitialize-display",
    },
    {
        title: "Potluck Bot",
        category: "Discord Bot",
        description:
            "A Discord bot for organizing potluck events with interactive item management. Users can create potlucks, claim items, add custom items, and sync with Discord scheduled events — all through buttons in chat.",
        tags: ["TypeScript", "discord.js", "SQLite"],
        image: potluckBotImg,
        imageAlt:
            "Potluck Bot icon, a smiling orange cooking pot with a 'potluck' speech bubble",
        imageType: "icon" as const,
        repoUrl: "https://github.com/JosNun/potluck-bot",
    },
    {
        title: "Versetime",
        category: "Web App",
        description:
            "A rebuild of Hangtime to meet changing needs. Rather than manually added words that get rotated through, the user specifies a Bible reference, and we fetch the text via api.",
        tags: ["Svelte"],
        image: versetimeImg,
        imageAlt:
            "Versetime running on a TV, showing a partially obscured Bible verse and a countdown timer for a memorization round",
        liveUrl: "https://versetime.josnun.com",
        repoUrl: "https://github.com/JosNun/versetime",
    },
    {
        title: "Hangtime",
        category: "Web App",
        description:
            "Hangman + a countdown timer. Built to handle a need I had in kids ministry. Built with Svelte because I hadn't used it yet.",
        tags: ["Svelte"],
        image: hangtimeImg,
        imageAlt:
            "Hangtime running on a TV, showing a hangman-style word puzzle with letters revealed and a countdown timer",
        liveUrl: "https://hangtime.josnun.com",
        repoUrl: "https://github.com/JosNun/hangtime",
    },
    {
        title: "Free-Range Ideas",
        category: "Web App",
        description:
            "A public shelf of project ideas free for the taking — if one sparks you, build it. A vibe-coded side project; the design is intentionally hasty and evolving.",
        tags: ["Astro", "Vibe Coded"],
        image: freeRangeIdeasImg,
        imageAlt:
            "Free-Range Ideas icon, a carton of smiling eggs with a glowing lightbulb in place of one egg",
        imageType: "icon" as const,
        liveUrl: "https://ideas.josnun.com",
        repoUrl: "https://github.com/JosNun/free-range-ideas",
    },
    {
        title: "Sitant",
        category: "Chrome Extension",
        description:
            "A minimal, yet incredibly functional new tab replacement. It provides a quick place to jot down notes, todos, or tasks without a bunch of additional fluff.",
        tags: ["Chrome Extension", "React"],
        image: sitantImg,
        imageAlt:
            "Sitant new tab page on a laptop, showing a minimal todo input with a list of tasks and completed items below",
        liveUrl:
            "https://chromewebstore.google.com/detail/sitant-simple-tasks-in-ne/koggochfeennbhkkjmbpbhfhociingae",
        repoUrl: "https://github.com/JosNun/sitant",
    },
    {
        title: "Parabox",
        category: "Library",
        description:
            "An easy-to-use parallax library built on top of CSS3 transforms. Available for use both in-browser and with modern build systems.",
        tags: ["JavaScript", "CSS"],
        liveUrl: "https://codepen.io/FracturedLoop/full/VBXpbj/",
        repoUrl: "https://github.com/JosNun/parabox.js",
    },
    {
        title: "PrayerShare",
        category: "Web App",
        description:
            "A pseudo-anonymous prayer request sharing platform. Users are able to follow their friends, and see when a request is made, but the poster will remain anonymous.",
        tags: ["React"],
        image: prayershareImg,
        imageAlt:
            "PrayerShare iPhone screen showing a feed of anonymous prayer requests with reaction buttons for each post",
        archived: true,
    },
    {
        title: "Codenames",
        category: "Game",
        description:
            "A digital version of the board game enabling real-time multiplayer gameplay from any device. The real-time communication runs on WebSockets and is powered by Socket.io.",
        tags: ["Node.js", "Socket.io", "WebSockets"],
        image: codenamesImg,
        imageAlt:
            "Codenames web game on a laptop, showing the 5x5 word grid mid-game with red and blue team outlines and a side chat panel",
        repoUrl: "https://github.com/JosNun/codenames",
        archived: true,
    },
    {
        title: "Ascend Performance",
        category: "Practice Site",
        description:
            "A fictitious company website project used to practice design skills and experiment with new technologies like Styled Components.",
        tags: ["React", "Styled Components"],
        image: ascendImg,
        imageAlt:
            "Ascend Performance fitness website displayed on a phone with a 'Enabling YOU to do more' hero, product feature cards, and call-to-action",
        repoUrl: "https://github.com/JosNun/ascend-performance",
        archived: true,
    },
];

const sortedProjects = projects
    .slice()
    .sort((a, b) => Number(a.archived ?? false) - Number(b.archived ?? false));

const description =
    "Most of these exist because I wanted them to. Some shipped, some lived briefly, some are still kicking. Built to scratch an itch.";

const siteUrl = Astro.site!.toString().replace(/\/$/, "");
const projectsCollection = {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": `${siteUrl}/projects/#page`,
    url: `${siteUrl}/projects`,
    name: "Projects",
    description,
    author: { "@id": `${siteUrl}/#person` },
    mainEntity: {
        "@type": "ItemList",
        itemListElement: sortedProjects.map((project, index) => {
            const projectUrl = project.liveUrl ?? project.repoUrl;
            return {
                "@type": "ListItem",
                position: index + 1,
                item: {
                    "@type": "CreativeWork",
                    name: project.title,
                    description: project.description,
                    creator: { "@id": `${siteUrl}/#person` },
                    ...(projectUrl ? { url: projectUrl } : {}),
                    ...(project.image
                        ? {
                              image: new URL(
                                  project.image.src,
                                  Astro.site,
                              ).toString(),
                          }
                        : {}),
                },
            };
        }),
    },
};
---

<BaseLayout
    title="Projects - Josiah Nunemaker"
    description={description}
    jsonLd={projectsCollection}
>
    <main class="max-w-5xl mx-auto px-8 py-20">
        <PageHeader
            title="Projects"
            subtitle="Things I've built, tinkered with, or shipped"
        />

        <div class="space-y-8">
            {sortedProjects.map((project) => <ProjectCard {...project} />)}
        </div>
    </main>
</BaseLayout>
