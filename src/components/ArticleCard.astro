---
import { formatMonthYear } from '../utils/formatDate';

interface Props {
  title: string;
  date: Date;
  description: string;
  slug: string;
  archived?: boolean;
}

const { title, date, description, slug, archived = false } = Astro.props;
const formattedDate = formatMonthYear(date);
---

<a href={`/writing/${slug}/`} class="group block p-10 hover:bg-white article-hover">
  <div class="flex items-baseline gap-4 mb-6">
    <time class="font-mono text-xs uppercase tracking-wider text-bark">
      {formattedDate}
    </time>
    {archived && (
      <span class="font-mono text-xs uppercase tracking-wider text-bark opacity-60">
        archived
      </span>
    )}
  </div>
  <h2 class="text-3xl font-light mb-6 group-hover:opacity-70 transition text-forest">
    {title}
  </h2>
  <p class="text-lg leading-relaxed mb-8 text-sage">
    {description}
  </p>
  <span class="font-mono text-sm arrow-link text-moss">
    → read article
  </span>
</a>
