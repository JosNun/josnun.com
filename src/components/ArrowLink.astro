---
interface Props {
  href: string;
  text: string;
  class?: string;
  external?: boolean;
}

const { href, text, class: className = '', external = false } = Astro.props;
---

<a
  href={href}
  class={`arrow-link text-moss ${className}`}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
>
  → {text}
</a>
