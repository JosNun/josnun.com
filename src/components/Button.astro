---
interface Props {
  href: string;
  external?: boolean;
  class?: string;
}

const { href, external, class: className = '' } = Astro.props;
const rel = external ? 'noopener noreferrer' : undefined;
const target = external ? '_blank' : undefined;
---

<a
  href={href}
  rel={rel}
  target={target}
  class={`inline-block px-4 py-2 font-mono text-xs border border-forest text-forest hover:bg-forest hover:text-cream transition-colors ${className}`}
>
  <slot />
</a>
