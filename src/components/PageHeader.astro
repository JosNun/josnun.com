---
interface Props {
  title: string;
  subtitle?: string;
  meta?: string;
}

const { title, subtitle, meta } = Astro.props;
---

<header class="mb-20 fade-in">
  <h1 class="text-5xl sm:text-6xl md:text-7xl font-light tracking-tight mb-6 text-forest">
    {title}
  </h1>
  <div class="h-px w-16 mb-6 stem-line"></div>
  {subtitle && (
    <p class="text-xl font-light text-sage">
      {subtitle}
    </p>
  )}
  {meta && (
    <p class="font-mono text-xs tracking-wider uppercase text-bark mt-6">
      {meta}
    </p>
  )}
</header>
